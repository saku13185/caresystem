# ==============================================================================
# 스마트시티 예방적 돌봄 AI 에이전트 시스템 환경 변수 설정 템플릿 (.env.example)
# ==============================================================================

# Google Gemini API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 Gemini 또는 Gemma 모델명 (최신 flash 2.5)
GEMINI_MODEL=gemini-2.5-flash

# PyTorch 연산 및 추론용 가중치 파일 기본 경로
MODEL_PATH=attention_rnn.pt

# SQLite 로컬 데이터베이스 저장 파일명
DATABASE_PATH=care_system.db

# 대시보드 로그인 보안 마스터 비밀번호 단방향 PBKDF2-SHA256 해시값
# (원문 예시: "care1234" 에 대한 정합성 해시 템플릿입니다. 상용 배포 시에는 변경하십시오)
MASTER_PASSWORD_HASH=pbkdf2_sha256$260000$staticsalt1234$aa9370e94d0278870dbf59c2a7d5a88cb25786708e145dfae3319623b432af71

# [안내] 새 마스터 비밀번호 해시를 생성하려면 가상환경 활성화 상태에서 아래 헬퍼 스크립트를 구동하십시오:
# python scripts/generate_password_hash.py
